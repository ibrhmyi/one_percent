# ── OnePercent Trading Engine ──

# Supabase (required for Vercel frontend sync + order persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Polymarket CLOB (required for live trading, optional for dry-run)
POLY_PRIVATE_KEY=
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=1
POLYMARKET_ADDRESS=0x...

# Trading config
DRY_RUN=true
BANKROLL=10000

# Exit strategy tuning (all optional, sane defaults built in)
# EXIT_TARGET_PRICE=0.92
# EXIT_REVERSAL_CENTS=10
# EXIT_STALL_MINUTES=5
# EXIT_TIMEOUT_HOURS=24

# Kelly criterion tuning (optional)
# KELLY_FRACTION=0.5
# MAX_POSITION_PCT=0.25
# MIN_KELLY_BET=5

# The Odds API (pre-game edge skill, optional)
# ODDS_API_KEY_1=
# ODDS_API_KEY_2=
