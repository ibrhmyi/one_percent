# Polymarket CLOB (no auth needed for public book data)
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

# Momentum detection thresholds
VELOCITY_THRESHOLD=0.04
WINDOW_MS=4000
MIN_YES_BID=0.05
MAX_YES_BID=0.75
COOLDOWN_MS=30000

# Risk
POSITION_SIZE_USD=25
MAX_OPEN_POSITIONS=3
MAX_TOTAL_EXPOSURE_USD=150

# Paper trade mode (MUST be true until manually disabled)
DRY_RUN=true
